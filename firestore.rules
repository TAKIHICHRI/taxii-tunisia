// ملف: firestore.rules
// انسخ هذا الكود في Firebase Console → Firestore → Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // المستخدمون: كل مستخدم يقرأ/يكتب بياناته فقط
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // الرحلات: كل مستخدم يقرأ/يكتب رحلاته فقط
    match /rides/{rideId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    // طلبات السائقين: أي مستخدم مسجّل يقدّم طلباً
    match /driverApplications/{appId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null;
    }

    // الإشعارات: كل مستخدم يقرأ إشعاراته فقط
    match /notifications/{notifId} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }
  }
}
